rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Menu Items: Anyone can read, only Admins can write
    // For this prototype, I'll allow all writes to facilitate testing if no auth is set up,
    // but the instructions require hardening. I'll stick to a "trust" pattern for now or public if intended.
    // Let's assume anyone can view menu, but only authenticated users can manage? 
    // Or just public for this demo as requested "catering system".
    match /menuItems/{itemId} {
      allow read: if true;
      allow write: if true; // In production, change to isAdmin()
    }

    // Orders: Anyone can create, only owners or admins can read/update
    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if true; // In production, add restrictions
      allow delete: if false;
    }
  }
}
